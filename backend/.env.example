# Server
PORT=3001
NODE_ENV=development

# Database - Supabase PostgreSQL
# Lấy từ Supabase Dashboard → Settings → Database → Connection string → URI
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_DB_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Supabase (optional - for future features)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_KEY=your_supabase_anon_key

# JWT Authentication
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
BCRYPT_SALT_ROUNDS=12

# CORS - Frontend URL
CORS_ORIGIN=http://localhost:5173

# File Uploads
UPLOAD_DIR=uploads
